# Copy to .env.local for local dev (Vercel CLI picks it up).
# In production: set these in Vercel > Settings > Environment Variables.

# Airtable Personal Access Token (starts with "pat")
# Scopes required: data.records:read, data.records:write on your base.
AIRTABLE_TOKEN=pat_xxx

# Airtable base id (starts with "app")
AIRTABLE_BASE_ID=app_xxx

# PIN that unlocks the /logbook page.
# Any string; keep it short and memorable.
LOGBOOK_PIN=change-me
