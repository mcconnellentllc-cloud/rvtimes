# Copy to .env.local for local dev. In production these are set in Vercel > Settings > Environment Variables.

# The single shared password to enter the site
SITE_PASSWORD=change-me

# Secret used to sign the auth cookie (any long random string)
AUTH_SECRET=change-me-to-a-long-random-string

# Airtable
AIRTABLE_API_KEY=pat_xxx
AIRTABLE_BASE_ID=app_xxx
